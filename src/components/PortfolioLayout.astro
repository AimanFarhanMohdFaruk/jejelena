---
import BaseHead from './BaseHead.astro';
import Footer from './Footer.astro';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<slot />
		<Footer />
	</body>
</html>
