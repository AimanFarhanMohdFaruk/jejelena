---
import type { Project } from '../data/projects';

interface Props {
	project: Project;
	index: number;
	total: number;
	nextHref: string;
}

const { project, index, total, nextHref } = Astro.props;
---

<article class="case-panel" id={`project-${project.name}`}>
	<div class="case-inner">
		<p class="eyebrow">
			Case study {String(index + 1).padStart(2, '0')} / {String(total).padStart(2, '0')}
		</p>
		<div class="meta">
			{project.period && <span>{project.period}</span>}
			<span class="status">{project.status}</span>
		</div>
		<h2>{project.title}</h2>
		<p class="tagline">{project.tagline}</p>
		<p class="summary">{project.summary}</p>
		{project.sector && <p class="sector">{project.sector}</p>}
		<ul class="tech" aria-label="Technologies">
			{project.tech.slice(0, 7).map((t) => <li>{t}</li>)}
		</ul>
		<div class="actions">
			<a class="cta" href={`/projects/${project.name}`}>Read full case study →</a>
			<a class="next" href={nextHref}>Next ↓</a>
		</div>
	</div>
</article>

<style>
	.case-panel {
		display: flex;
		align-items: center;
		box-sizing: border-box;
		width: 100%;
		height: 100svh;
		min-height: 100svh;
		padding: 3rem 0;
		scroll-snap-align: start;
		scroll-snap-stop: always;
		overflow: hidden;
	}

	.case-inner {
		width: 860px;
		max-width: calc(100% - 2.5rem);
		margin: 0 auto;
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-size: 0.75rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-faint);
	}

	.meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1.25rem;
		margin-bottom: 0.85rem;
		font-size: 0.8rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--text-faint);
	}

	.status {
		color: var(--text-muted);
	}

	h2 {
		margin: 0 0 0.5rem;
		font-size: clamp(1.85rem, 5vw, 3rem);
	}

	.tagline {
		margin: 0 0 1.15rem;
		font-size: 1.1rem;
		color: var(--text-muted);
	}

	.summary {
		margin: 0 0 1rem;
		max-width: 40rem;
		font-size: 0.98rem;
		line-height: 1.65;
		color: var(--text-muted);
		display: -webkit-box;
		-webkit-line-clamp: 5;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.sector {
		margin: 0 0 1.35rem;
		font-size: 0.85rem;
		color: var(--text-faint);
	}

	.tech {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		list-style: none;
		margin: 0 0 1.75rem;
		padding: 0;
	}

	.tech li {
		margin: 0;
		padding: 0.25rem 0.65rem;
		font-size: 0.75rem;
		color: var(--text-muted);
		border: 1px solid var(--line);
		border-radius: 999px;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1.25rem 2rem;
	}

	.cta,
	.next {
		font-size: 0.9rem;
		text-decoration: none;
		color: var(--accent);
	}

	.cta:hover,
	.next:hover {
		color: #fff;
	}

	.next {
		color: var(--text-faint);
	}

	@media (max-width: 720px) {
		.case-panel {
			align-items: flex-start;
			padding: 2.5rem 0;
			overflow-y: auto;
		}

		.summary {
			-webkit-line-clamp: 6;
		}
	}
</style>
