---
import PortfolioLayout from '../../components/PortfolioLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { SITE_TITLE } from '../../consts';
import { projects } from '../../data/projects';
---

<PortfolioLayout
	title={`Work — ${SITE_TITLE}`}
	description="Selected platform and product work by Aiman Farhan."
>
	<main>
		<nav class="breadcrumb">
			<a href="/">Home</a>
			<span>/</span>
			<span>Work</span>
		</nav>

		<header class="page-head" data-aos="fade-up">
			<p class="eyebrow">Selected work</p>
			<h1>Projects</h1>
			<p class="intro">
				Platform partnerships, legacy rescues, and product work — from mobile access to payments.
			</p>
		</header>

		<div class="project-list">
			{projects.map((project, i) => (
				<ProjectCard project={project} featured={i === 0} />
			))}
		</div>
	</main>
</PortfolioLayout>

<style>
	main {
		padding-top: 2.5rem;
	}

	.breadcrumb {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 2.5rem;
		font-size: 0.85rem;
		color: var(--text-faint);
	}

	.breadcrumb a {
		color: var(--text-muted);
		text-decoration: none;
	}

	.breadcrumb a:hover {
		color: var(--text);
	}

	.page-head {
		margin-bottom: 1.5rem;
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		font-size: 0.75rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-faint);
	}

	h1 {
		margin: 0 0 0.75rem;
		font-size: clamp(2.25rem, 6vw, 3.5rem);
	}

	.intro {
		max-width: 32rem;
		margin: 0;
		color: var(--text-muted);
	}

	.project-list {
		border-bottom: 1px solid var(--line);
	}
</style>
