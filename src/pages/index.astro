---
import PortfolioLayout from '../components/PortfolioLayout.astro';
import CaseStudyPanel from '../components/CaseStudyPanel.astro';
import {
	SITE_TITLE,
	SITE_DESCRIPTION,
	SITE_NAME,
	SITE_ROLE,
	SITE_EMAIL,
	SITE_LINKEDIN,
	SITE_GITHUB,
} from '../consts';
import { projects } from '../data/projects';

const firstProject = projects[0];
const firstProjectHref = firstProject ? `#project-${firstProject.name}` : '#contact';
---

<PortfolioLayout title={SITE_TITLE} description={SITE_DESCRIPTION} hideFooter bodyClass="snap-page">
	<div class="snap">
		<section class="panel hero" id="top" aria-label="Introduction">
			<div class="hero-frame">
				<div class="hero-copy">
					<p class="role">{SITE_ROLE}</p>
					<h1>{SITE_NAME}</h1>
					<p class="lede">
						I build and rescue platforms — APIs, native mobile, payments, and the delivery
						systems that keep them alive across regions.
					</p>
					<a class="scroll" href={firstProjectHref}>
						Selected work
						<span class="arrow" aria-hidden="true">↓</span>
					</a>
				</div>
				<figure class="hero-portrait">
					<img
						src="/images/aiman-portrait.png"
						alt={`${SITE_NAME}, ${SITE_ROLE}`}
						width="720"
						height="960"
					/>
				</figure>
			</div>
		</section>

		{
			projects.map((project, i) => (
				<CaseStudyPanel
					project={project}
					index={i}
					total={projects.length}
					nextHref={
						i < projects.length - 1
							? `#project-${projects[i + 1].name}`
							: '#contact'
					}
				/>
			))
		}

		<section class="panel contact" id="contact" aria-labelledby="contact-heading">
			<div class="contact-inner">
				<p class="eyebrow">Contact</p>
				<h2 id="contact-heading">Let’s talk</h2>
				<p class="contact-lede">
					Open to interesting platform work, technical leadership, and collaborations.
				</p>
				<ul class="contact-links">
					<li>
						<a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a>
					</li>
					<li>
						<a href={SITE_LINKEDIN} target="_blank" rel="noopener noreferrer">LinkedIn</a>
					</li>
					<li>
						<a href={SITE_GITHUB} target="_blank" rel="noopener noreferrer">GitHub</a>
					</li>
				</ul>
				<p class="copy">© {new Date().getFullYear()} Aiman Farhan</p>
			</div>
		</section>
	</div>
</PortfolioLayout>

<style is:global>
	body.snap-page {
		height: 100svh;
		overflow: hidden;
	}
</style>

<style>
	.snap {
		height: 100svh;
		overflow-y: auto;
		scroll-snap-type: y mandatory;
		scroll-behavior: smooth;
		overscroll-behavior-y: contain;
	}

	.panel {
		box-sizing: border-box;
		height: 100svh;
		min-height: 100svh;
		scroll-snap-align: start;
		scroll-snap-stop: always;
	}

	.hero {
		display: flex;
		align-items: center;
		padding: 2rem 0;
	}

	.hero-frame {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 0.95fr);
		align-items: center;
		gap: 2rem 3rem;
		width: 960px;
		max-width: calc(100% - 2.5rem);
		margin: 0 auto;
	}

	.hero-copy {
		display: flex;
		flex-direction: column;
		justify-content: center;
		min-width: 0;
	}

	.role {
		margin: 0 0 1.25rem;
		font-size: 0.8rem;
		font-weight: 500;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.hero h1 {
		margin: 0 0 1.5rem;
		opacity: 0.96;
		text-shadow: 0 0 60px rgba(180, 190, 210, 0.12);
		animation: ghost-breath 7s var(--ease-out) infinite alternate;
	}

	.lede {
		max-width: 28rem;
		margin: 0 0 2.75rem;
		font-size: 1.15rem;
		line-height: 1.6;
		color: var(--text-muted);
	}

	.scroll {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		width: fit-content;
		font-size: 0.9rem;
		color: var(--accent);
		text-decoration: none;
	}

	.scroll:hover {
		color: #fff;
	}

	.arrow {
		display: inline-block;
		animation: float-down 2.4s var(--ease-out) infinite;
	}

	.hero-portrait {
		margin: 0;
		justify-self: end;
		width: min(100%, 22rem);
	}

	.hero-portrait img {
		display: block;
		width: 100%;
		height: auto;
		object-fit: cover;
		object-position: center top;
		opacity: 0.98;
		-webkit-mask-image:
			linear-gradient(to bottom, transparent 0%, #000 12%, #000 78%, transparent 100%),
			linear-gradient(to right, transparent 0%, #000 10%, #000 88%, transparent 100%);
		mask-image:
			linear-gradient(to bottom, transparent 0%, #000 12%, #000 78%, transparent 100%),
			linear-gradient(to right, transparent 0%, #000 10%, #000 88%, transparent 100%);
		-webkit-mask-composite: source-in;
		mask-composite: intersect;
		animation: portrait-drift 9s var(--ease-out) infinite alternate;
	}

	@keyframes ghost-breath {
		from {
			opacity: 0.88;
		}
		to {
			opacity: 1;
		}
	}

	@keyframes float-down {
		0%,
		100% {
			transform: translateY(0);
			opacity: 0.7;
		}
		50% {
			transform: translateY(5px);
			opacity: 1;
		}
	}

	@keyframes portrait-drift {
		from {
			opacity: 0.94;
			transform: translateY(0);
		}
		to {
			opacity: 1;
			transform: translateY(-6px);
		}
	}

	.contact {
		display: flex;
		align-items: center;
	}

	.contact-inner {
		width: 860px;
		max-width: calc(100% - 2.5rem);
		margin: 0 auto;
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		font-size: 0.75rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-faint);
	}

	.contact h2 {
		margin: 0 0 0.75rem;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
	}

	.contact-lede {
		max-width: 26rem;
		margin: 0 0 2rem;
		color: var(--text-muted);
	}

	.contact-links {
		list-style: none;
		margin: 0 0 3rem;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.contact-links a {
		font-size: 1.05rem;
		text-decoration: none;
		color: var(--accent);
	}

	.contact-links a:hover {
		color: #fff;
	}

	.copy {
		margin: 0;
		font-size: 0.8rem;
		letter-spacing: 0.04em;
		color: var(--text-faint);
	}

	@media (max-width: 820px) {
		.hero-frame {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.hero-portrait {
			order: -1;
			justify-self: center;
			width: min(55%, 14rem);
		}

		.lede {
			margin-bottom: 1.75rem;
			font-size: 1.05rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.snap {
			scroll-snap-type: none;
			scroll-behavior: auto;
		}

		.hero h1,
		.hero-portrait img,
		.arrow {
			animation: none;
		}
	}
</style>
