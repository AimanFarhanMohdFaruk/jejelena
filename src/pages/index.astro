---
import PortfolioLayout from '../components/PortfolioLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import {
	SITE_TITLE,
	SITE_DESCRIPTION,
	SITE_NAME,
	SITE_ROLE,
	SITE_EMAIL,
	SITE_LINKEDIN,
	SITE_GITHUB,
} from '../consts';
import { projects } from '../data/projects';
---

<PortfolioLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main>
		<section class="hero" aria-label="Introduction">
			<div class="hero-copy">
				<p class="role" data-aos="fade-up">{SITE_ROLE}</p>
				<h1 data-aos="fade-up" data-aos-delay="80">{SITE_NAME}</h1>
				<p class="lede" data-aos="fade-up" data-aos-delay="160">
					I build and rescue platforms — APIs, native mobile, payments, and the delivery
					systems that keep them alive across regions.
				</p>
				<a class="scroll" href="#work" data-aos="fade-up" data-aos-delay="240">
					Selected work
					<span class="arrow" aria-hidden="true">↓</span>
				</a>
			</div>
			<figure class="hero-portrait" data-aos="fade-in" data-aos-delay="200">
				<img
					src="/images/aiman-portrait.png"
					alt={`${SITE_NAME}, ${SITE_ROLE}`}
					width="720"
					height="960"
				/>
			</figure>
		</section>

		<section id="work" class="work" aria-labelledby="work-heading">
			<div class="section-head" data-aos="fade-up">
				<p class="eyebrow">Selected work</p>
				<h2 id="work-heading">Projects</h2>
			</div>

			<div class="project-list">
				{projects.map((project, i) => (
					<ProjectCard project={project} featured={i === 0} />
				))}
			</div>
		</section>

		<section id="contact" class="contact" aria-labelledby="contact-heading" data-aos="fade-up">
			<p class="eyebrow">Contact</p>
			<h2 id="contact-heading">Let’s talk</h2>
			<p class="contact-lede">
				Open to interesting platform work, technical leadership, and collaborations.
			</p>
			<ul class="contact-links">
				<li>
					<a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a>
				</li>
				<li>
					<a href={SITE_LINKEDIN} target="_blank" rel="noopener noreferrer">LinkedIn</a>
				</li>
				<li>
					<a href={SITE_GITHUB} target="_blank" rel="noopener noreferrer">GitHub</a>
				</li>
			</ul>
		</section>
	</main>
</PortfolioLayout>

<style>
	main {
		width: 960px;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 0.95fr);
		align-items: center;
		gap: 2rem 3rem;
		min-height: 100svh;
		padding: 3rem 0 4rem;
	}

	.hero-copy {
		display: flex;
		flex-direction: column;
		justify-content: center;
		min-width: 0;
	}

	.role {
		margin: 0 0 1.25rem;
		font-size: 0.8rem;
		font-weight: 500;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.hero h1 {
		margin: 0 0 1.5rem;
		opacity: 0.96;
		text-shadow: 0 0 60px rgba(180, 190, 210, 0.12);
		animation: ghost-breath 7s var(--ease-out) infinite alternate;
	}

	.lede {
		max-width: 28rem;
		margin: 0 0 2.75rem;
		font-size: 1.15rem;
		line-height: 1.6;
		color: var(--text-muted);
	}

	.scroll {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		width: fit-content;
		font-size: 0.9rem;
		color: var(--accent);
		text-decoration: none;
	}

	.scroll:hover {
		color: #fff;
	}

	.arrow {
		display: inline-block;
		animation: float-down 2.4s var(--ease-out) infinite;
	}

	.hero-portrait {
		margin: 0;
		justify-self: end;
		width: min(100%, 22rem);
		position: relative;
	}

	.hero-portrait img {
		display: block;
		width: 100%;
		height: auto;
		object-fit: cover;
		object-position: center top;
		border-radius: 0;
		opacity: 0.98;
		-webkit-mask-image: linear-gradient(
			to bottom,
			transparent 0%,
			#000 12%,
			#000 78%,
			transparent 100%
		),
			linear-gradient(to right, transparent 0%, #000 10%, #000 88%, transparent 100%);
		mask-image: linear-gradient(
			to bottom,
			transparent 0%,
			#000 12%,
			#000 78%,
			transparent 100%
		),
			linear-gradient(to right, transparent 0%, #000 10%, #000 88%, transparent 100%);
		-webkit-mask-composite: source-in;
		mask-composite: intersect;
		animation: portrait-drift 9s var(--ease-out) infinite alternate;
	}

	@keyframes ghost-breath {
		from {
			opacity: 0.88;
			filter: blur(0);
		}
		to {
			opacity: 1;
			filter: blur(0.15px);
		}
	}

	@keyframes float-down {
		0%,
		100% {
			transform: translateY(0);
			opacity: 0.7;
		}
		50% {
			transform: translateY(5px);
			opacity: 1;
		}
	}

	@keyframes portrait-drift {
		from {
			opacity: 0.94;
			transform: translateY(0);
		}
		to {
			opacity: 1;
			transform: translateY(-6px);
		}
	}

	.work {
		padding: 1rem 0 4rem;
	}

	.section-head {
		margin-bottom: 1rem;
	}

	.eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.75rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-faint);
	}

	.section-head h2 {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.project-list {
		border-bottom: 1px solid var(--line);
	}

	.contact {
		padding: 5rem 0 2rem;
		border-top: 1px solid var(--line);
	}

	.contact h2 {
		margin: 0 0 0.75rem;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
	}

	.contact-lede {
		max-width: 26rem;
		margin: 0 0 2rem;
		color: var(--text-muted);
	}

	.contact-links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.contact-links a {
		font-size: 1.05rem;
		text-decoration: none;
		color: var(--accent);
	}

	.contact-links a:hover {
		color: #fff;
	}

	@media (max-width: 820px) {
		.hero {
			grid-template-columns: 1fr;
			gap: 2rem;
			min-height: auto;
			padding: 2.5rem 0 3rem;
		}

		.hero-portrait {
			order: -1;
			justify-self: center;
			width: min(70%, 16rem);
		}

		.lede {
			font-size: 1.05rem;
		}
	}
</style>
